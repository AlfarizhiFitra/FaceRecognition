# Gunakan base image Python yang stabil
FROM python:3.10-slim

# Instal dependensi sistem operasi untuk C++, dlib, dan OpenCV
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    gfortran \
    git \
    wget \
    curl \
    graphicsmagick \
    libgraphicsmagick1-dev \
    libatlas-base-dev \
    libavcodec-dev \
    libavformat-dev \
    libgtk2.0-dev \
    libjpeg-dev \
    liblapack-dev \
    libswscale-dev \
    pkg-config \
    libpng-dev \
    libtiff5-dev \
    libx11-dev \
    libxext-dev \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Atur direktori kerja di dalam kontainer
WORKDIR /code

# Salin file requirements terlebih dahulu agar memanfaatkan cache Docker
COPY requirements.txt /code/requirements.txt

# Instal pustaka Python
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /code/requirements.txt

# Salin seluruh kode proyek ke dalam kontainer
COPY . .

# Berikan hak akses penuh ke direktori kerja (untuk caching dlib/wajah jika diperlukan)
RUN chmod -R 777 /code

# Jalankan aplikasi menggunakan Gunicorn pada port bawaan Hugging Face (7860)
CMD ["gunicorn", "-b", "0.0.0.0:7860", "app:app", "--timeout", "120"]